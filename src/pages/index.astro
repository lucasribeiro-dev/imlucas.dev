---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection, render } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const recentPosts = await Promise.all(
  posts.map(async (post) => {
    const { remarkPluginFrontmatter } = await render(post);
    return { ...post, minutesRead: remarkPluginFrontmatter.minutesRead };
  }),
);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0 -z-10">
      <div
        class="absolute left-1/2 top-1/4 h-[500px] w-[500px] -translate-x-1/2 rounded-full bg-accent/5 blur-[120px]"
      >
      </div>
      <div
        class="absolute bottom-0 left-1/4 h-[300px] w-[300px] rounded-full bg-accent/3 blur-[100px]"
      >
      </div>
    </div>

    <div class="mx-auto max-w-3xl px-6 pb-16 pt-24 text-center sm:pt-32">
      <p class="mb-4 font-mono text-xs tracking-widest text-text-dim uppercase">
        Software Engineer
      </p>

      <h1 class="mb-4 font-heading text-5xl font-bold tracking-tight sm:text-7xl">
        <span
          class="bg-gradient-to-r from-text via-accent to-text bg-[length:200%_100%] bg-clip-text text-transparent animate-[shimmer_5s_linear_infinite]"
        >
          imlucas
        </span>
        <span class="text-text-dim">.dev</span>
      </h1>

      <p class="mb-8 text-lg font-light text-text-muted sm:text-xl">
        Turning <span class="font-medium text-text">complexity</span> into
        <span class="font-medium text-text">clarity</span>
      </p>

      <p class="mx-auto max-w-lg text-sm leading-relaxed text-text-dim">
        AI deep-dives, system design breakdowns, and hard-won lessons from shipping real software.
        No fluff. No recycled takes. Just signal.
      </p>
    </div>
  </section>

  <!-- Recent Posts -->
  {
    recentPosts.length > 0 && (
      <section class="mx-auto max-w-3xl px-6 pb-20">
        <div class="mb-8 flex items-center justify-between">
          <h2 class="font-heading text-2xl font-semibold tracking-tight text-text">Recent Posts</h2>
          <a
            href="/blog"
            class="font-mono text-sm text-text-muted transition-colors hover:text-accent"
          >
            View all &rarr;
          </a>
        </div>

        <div class="flex flex-col gap-4">
          {recentPosts.map((post) => (
            <PostCard
              id={post.id}
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              minutesRead={post.minutesRead}
            />
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }
</style>
