---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SOCIAL_LINKS } from '../consts';
---

<BaseLayout
  title="About"
  description="About Lucas Ribeiro — software engineer, systems thinker, and full-stack builder."
>
  <div class="mx-auto max-w-3xl px-6 py-16">
    <header class="mb-12">
      <p class="mb-2 font-mono text-sm text-text-dim">// about</p>
      <h1 class="mb-4 font-heading text-4xl font-bold tracking-tight text-text sm:text-5xl">
        Lucas Ribeiro
      </h1>
      <p class="text-lg text-text-muted">Software Engineer</p>
    </header>

    <div class="space-y-6 text-text-muted leading-relaxed">
      <p>
        I build software that solves real problems. My work spans across
        <span class="text-text">distributed systems</span>,
        <span class="text-text">full-stack engineering</span>, and
        <span class="text-text">cloud architecture</span> — always with a focus on clean architecture
        and pragmatic design.
      </p>

      <p>
        This blog is where I share the insights that took years to earn, in minutes to read. Expect
        system design breakdowns, engineering war stories, and deep dives into the patterns behind
        reliable software.
      </p>

      <p>
        When I'm not shipping code, I'm digging into how systems scale, how teams build better
        tools, and what separates good engineering from great engineering.
      </p>
    </div>

    <!-- Interests -->
    <div class="mt-12">
      <h2 class="mb-4 font-heading text-xl font-semibold text-text">Focus Areas</h2>
      <div class="flex flex-wrap gap-2">
        {
          [
            'System Design',
            'Distributed Systems',
            'Full-Stack Engineering',
            'Developer Tools',
            'Cloud Architecture',
            'Performance',
          ].map((tag) => (
            <span class="rounded-md border border-border px-3 py-1.5 font-mono text-xs text-text-muted">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <!-- Connect -->
    <div class="mt-12">
      <h2 class="mb-4 font-heading text-xl font-semibold text-text">Connect</h2>
      <div class="flex gap-3">
        <a
          href={SOCIAL_LINKS.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 font-mono text-sm text-text-muted transition-colors hover:border-accent hover:text-accent"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
          GitHub
        </a>
        <a
          href={SOCIAL_LINKS.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg border border-border px-4 py-2 font-mono text-sm text-text-muted transition-colors hover:border-accent hover:text-accent"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
