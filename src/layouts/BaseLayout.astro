---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import { SITE } from '../consts';
import '../styles/global.css';
import spaceGroteskUrl from '@fontsource-variable/space-grotesk/files/space-grotesk-latin-wght-normal.woff2';

interface Props {
  title?: string;
  standaloneTitle?: string;
  description?: string;
  image?: string;
  type?: string;
}

const { title, standaloneTitle, description, image, type } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Preload critical font so it starts fetching in parallel with CSS -->
    <link rel="preload" href={spaceGroteskUrl} as="font" type="font/woff2" crossorigin />
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href="/rss.xml" />

    <!-- SEO -->
    <SEO
      title={title}
      standaloneTitle={standaloneTitle}
      description={description}
      image={image}
      type={type}
    />

    <!-- Google Search Console -->
    {
      SITE.gscVerification && (
        <meta name="google-site-verification" content={SITE.gscVerification} />
      )
    }

    <!-- Google Analytics -->
    {
      SITE.gaId && (
        <Fragment>
          <script
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${SITE.gaId}`}
            is:inline
          />
          <script
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments)}gtag('js',new Date());gtag('config','${SITE.gaId}');`}
            is:inline
          />
        </Fragment>
      )
    }

    <!-- Theme init (blocking — prevents flash) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const isDark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', isDark);
      })();
    </script>
  </head>
  <body class="flex min-h-screen flex-col bg-bg text-text">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
