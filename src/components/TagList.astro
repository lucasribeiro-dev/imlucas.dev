---
interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    tags.map((tag) => (
      <a
        href={`/tags/${tag}`}
        class="rounded-md border border-border px-2.5 py-1 font-mono text-xs text-text-muted transition-colors hover:border-accent hover:text-accent"
      >
        {tag}
      </a>
    ))
  }
</div>
