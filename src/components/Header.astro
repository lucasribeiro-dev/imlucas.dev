---
import ThemeToggle from './ThemeToggle.astro';
import Search from './Search.astro';
import { NAV_LINKS } from '../consts';

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-border bg-bg/80 backdrop-blur-md">
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 py-4">
    <a href="/" class="font-heading text-lg font-bold tracking-tight text-text">
      imlucas<span class="text-text-dim">.dev</span>
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden items-center gap-6 sm:flex">
        {
          NAV_LINKS.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'font-mono text-sm transition-colors hover:text-accent',
                  pathname === href || (href !== '/' && pathname.startsWith(href))
                    ? 'text-accent'
                    : 'text-text-muted',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>

      <Search />
      <ThemeToggle />

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="cursor-pointer text-text-muted sm:hidden"
      >
        <svg
          class="size-5"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5"
          ></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border px-6 py-4 sm:hidden">
    <ul class="flex flex-col gap-4">
      {
        NAV_LINKS.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[
                'font-mono text-sm transition-colors hover:text-accent',
                pathname === href || (href !== '/' && pathname.startsWith(href))
                  ? 'text-accent'
                  : 'text-text-muted',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script is:inline>
  document.getElementById('mobile-menu-btn').addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
